[qbittorrent]
url = "http://localhost:8080"
username = "admin"
# Optional if the QBITTORRENT_PASSWORD env var is set (the env var wins).
password = "password"

[watch]
paths = [
  "/data/media/movies",
  "/data/media/tv",
  "/data/downloads/complete",
]

[sync]
recheck_delay = 5
min_file_size_mb = 10

# Optional, repeatable: translate qBittorrent's paths to arr-sync's, like
# Sonarr/Radarr's Remote Path Mappings — only needed when the two don't
# mount the media at the same path.
# [[path_mappings]]
# remote = "/data/media"
# local = "/media"

# Optional: notify Sonarr/Radarr after a resync
[sonarr]
url = "http://localhost:8989"
api_key = "xxx"

[radarr]
url = "http://localhost:7878"
api_key = "xxx"
